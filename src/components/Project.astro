---
const { screenshots, title, tags, description, demoLink, codeLink } = Astro.props;
import { Image } from "astro:assets";
---

<article class="project flow">
  <div class="screenshots">
    {
      screenshots.map((screenshot) => {
        return (
          <Image
            class={screenshot.size}
            src={screenshot.src}
            alt={`${title} on ${screenshot.size}`}
          />
        );
      })
    }
  </div>

  <div class="title-container flex-flow align-center flex-wrap">
    <h3 class="fs-step-2">{title}</h3>
    <ul role="list" class="tags">
      {
        tags.map((tag) => {
          return <li class="tag fs-step--1">{tag}</li>;
        })
      }
    </ul>
  </div>

  <p>{description}</p>

  <div class="flex-flow">
    <a href={demoLink} class="button">Demo</a>
    <a href={codeLink} class="button">Code</a>
  </div>

  <div class="divider-lg"></div>
</article>

<style>
  .screenshots {
    display: flex;
    align-items: flex-end;
    filter: drop-shadow(0 3px 4px hsl(0 0% 0% / 0.5));
  }

  .screenshots img {
    min-width: 0;
    object-fit: cover;
    object-position: top;
  }

  .screenshots .tablet,
  .screenshots .mobile {
    margin-inline-start: -20px;

    @media (width < 48em) {
      display: none;
    }
  }

  .button {
    display: inline-block;
    color: var(--fg, var(--clr-primary-400));
    background: var(--bg, var(--clr-neutral-100));
    font-weight: bold;
    border: 3px solid var(--clr-primary-400);
    border-radius: 0.5rem;
    padding-inline: 2em;
    padding-block: 0.5em;
    cursor: pointer;
    transition:
      background 200ms ease-in,
      color 200ms ease-in;
  }

  .button:is(:hover, :focus-visible) {
    --fg: var(--clr-neutral-100);
    --bg: var(--clr-primary-400);
    outline-color: var(--clr-accent-1);
    outline-offset: 5px;
  }
</style>
